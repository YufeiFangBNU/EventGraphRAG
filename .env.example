# OpenAI API Configuration
# Copy this file to .env and fill in your actual API credentials

# Your OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL (optional - use if you have a custom endpoint)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative base URL examples:
# For custom API endpoints:
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1
# For Azure OpenAI:
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# Model Configuration (optional)
# Default model for text generation
DEFAULT_MODEL=qwen2.5-7b-instruct

# Default model for embeddings
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Advanced Configuration (optional)
# Maximum tokens for embedding requests (default: 8000)
MAX_EMBEDDING_TOKENS=8000

# Number of parallel workers for LLM requests (default: 8)
MAX_WORKERS=8

# Request timeout in seconds (optional)
# REQUEST_TIMEOUT=30

# Debug mode (optional)
# DEBUG=false